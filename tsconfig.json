{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node20",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "declaration": true
  },
  "include": ["src", "test"],
  "exclude": ["src/typechain-types"]
}